# Production Environment Variables
# Copy this file to .env and fill in your values

# Server
PORT=5000
NODE_ENV=production

# MongoDB (use MongoDB Atlas for production)
# Get your connection string from https://cloud.mongodb.com
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.xxxxx.mongodb.net/webmark?retryWrites=true&w=majority

# JWT Configuration (CHANGE THIS! Use a strong random string)
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secure_random_string_at_least_64_characters_long
JWT_EXPIRES_IN=7d

# Client URL (your deployed frontend URL)
CLIENT_URL=https://your-app.vercel.app

# Email Configuration
# For production, use real Gmail credentials or a service like SendGrid
USE_ETHEREAL=false
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-16-char-app-password
